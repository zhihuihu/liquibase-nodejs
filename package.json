{
  "name": "@nisec/liquibase",
  "version": "1.0.0",
  "description": "Liquibase-compatible database migration tool for Node.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nisec-liquibase": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "liquibase",
    "database",
    "migration",
    "changelog",
    "changeset",
    "postgresql",
    "mysql",
    "mariadb",
    "schema",
    "cluster-safe"
  ],
  "license": "MIT",
  "author": "huzhihui",
  "repository": {
    "type": "git",
    "url": "https://github.com/nisec/liquibase-nodejs"
  },
  "bugs": {
    "url": "https://github.com/nisec/liquibase-nodejs/issues"
  },
  "homepage": "https://github.com/nisec/liquibase-nodejs#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "mysql2": "^3.0.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "dependencies": {
    "fast-xml-parser": "^4.3.0",
    "glob": "^10.3.0",
    "md5": "^2.3.0"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/md5": "^2.3.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "mysql2": "^3.22.3",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
