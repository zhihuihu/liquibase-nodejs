    "glob": "^10.3.0",
    "md5": "^2.3.0"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/md5": "^2.3.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "mysql2": "^3.22.3",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
